{
  "source": {
    "server": "192.168.1.100",
    "port": 1433,
    "username": "sa",
    "password": "yourpassword",
    "encrypt": false,
    "trustServerCertificate": true
  },
  "target": {
    "server": "192.168.2.100",
    "port": 1433,
    "username": "sa",
    "password": "yourpassword",
    "encrypt": false,
    "trustServerCertificate": true
  },
  "databases": [
    {
      "comment": "Tenant filter with per-table overrides",
      "sourceDatabase": "MainAppDB",
      "targetDatabase": "MainAppDB_Staging",
      "tableFilter": "tenant",
      "tenantId": "42",
      "overrides": [
        {
          "name": "dbo.HugeTable_42",
          "where": "CreatedAt >= '2024-01-01'"
        },
        {
          "name": "dbo.BigTable_42",
          "query": "SELECT TOP 1000 * FROM [dbo].[BigTable_42] ORDER BY CreatedAt DESC"
        },
        {
          "name": "dbo.UnwantedTable_42",
          "ignore": true
        }
      ]
    },
    {
      "comment": "Explicit table list",
      "sourceDatabase": "ReportingDB",
      "targetDatabase": "ReportingDB_Staging",
      "tableFilter": "explicit",
      "tables": [
        "dbo.SmallTable",
        {
          "name": "dbo.HugeTable",
          "where": "CreatedAt >= '2024-01-01'"
        },
        {
          "name": "dbo.UnwantedTable",
          "ignore": true
        }
      ]
    },
    {
      "comment": "All tables",
      "sourceDatabase": "LookupDB",
      "targetDatabase": "LookupDB_Staging",
      "tableFilter": "all",
      "overrides": [
        {
          "name": "dbo.LargeAuditLog",
          "ignore": true
        }
      ]
    }
  ]
}