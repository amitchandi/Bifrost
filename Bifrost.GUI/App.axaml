<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Bifrost.GUI"
             x:Class="Bifrost.GUI.App">
  <Application.Styles>
    <FluentTheme />
  </Application.Styles>
  <Application.Resources>
    <local:LogLineColorConverter x:Key="LogLineColorConverter"/>
    <local:BoolToColorConverter x:Key="BoolToColorConverter"/>
  </Application.Resources>
  <TrayIcon.Icons>
    <TrayIcons>
      <TrayIcon ToolTipText="Bifrost" Icon="avares://bifrost-gui/Assets/bifrost.ico" Command="{x:Static local:App.ShowWindowCommand}">
        <TrayIcon.Menu>
          <NativeMenu>
            <NativeMenuItem Header="Show Bifrost" Command="{x:Static local:App.ShowWindowCommand}"/>
            <NativeMenuItemSeparator/>
            <NativeMenuItem Header="Quit" Command="{x:Static local:App.QuitCommand}"/>
          </NativeMenu>
        </TrayIcon.Menu>
      </TrayIcon>
    </TrayIcons>
  </TrayIcon.Icons>
</Application>
